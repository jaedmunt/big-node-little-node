# Model paths - update to your paths. This example is given for my machines
# Your desktop model. Handled by huggingface, therefore no route needed
DESKTOP_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ

# The path to your llama.cpp model on your Raspberry Pi
PI_MODEL_PATH=/home/admin/Desktop/ray-pi/models/tinyllama-1.1b-chat-v0.3.Q4_K_M.gguf

# Router ports — used by interface/router.py and interface/src/main.rs (Rig.rs)
# Start the router first: python interface/router.py
DESKTOP_ENDPOINT=http://localhost:8100/v1
PI_ENDPOINT=http://localhost:8101/v1
PI_MODEL_NAME=tinyllama
DESKTOP_ROUTER_PORT=8100
PI_ROUTER_PORT=8101
